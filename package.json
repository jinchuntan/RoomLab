{
  "name": "roomlab",
  "version": "0.1.0",
  "private": true,
  "description": "RoomLab is a multiplayer, co-located spatial learning prototype for Spectacles-style XR collaboration.",
  "scripts": {
    "setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup.ps1",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:simulator\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:browser": "vite --config simulator/vite.config.ts",
    "dev:simulator": "vite --config simulator/vite.config.ts",
    "build": "npm run build:server && npm run build:lens && npm run build:simulator",
    "build:vercel": "npm run build:simulator",
    "build:server": "tsc -p server/tsconfig.json",
    "build:lens": "tsc -p lens/tsconfig.json",
    "build:simulator": "vite build --config simulator/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit && tsc -p lens/tsconfig.json --noEmit && tsc -p simulator/tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "preview": "vite preview --config simulator/vite.config.ts",
    "start:server": "node dist/server/server/src/index.js"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.26.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  }
}
